# Copy this file to .env and set strong, local-only credentials.

# Published host ports
TODO_CLIENT_PORT=8080
TODO_APP_SERVER_PORT=8081
ECHO_SERVICE_PORT=8088
IDENTITY_PROVIDER_PORT=8090
TODO_POSTGRES_HOST_PORT=8999
TODO_DB_HOST_PORT=3307
ADMINER_PORT=8083

# Identity provider / Postgres
IDP_HOST=0.0.0.0
IDP_PORT=8080
IDP_CORS_ORIGIN=http://localhost:8080,http://localhost:8081
IDP_DB_HOST=todo_postgres
IDP_DB_PORT=5432
IDP_DB_USER=change_me_idp_user
IDP_DB_PASSWORD=change_me_idp_password

# Optional override used by the identity provider stack
IDP_DB_JDBC_STRING=jdbc:postgresql://todo_postgres:5432/idp

# To-do MariaDB
TODO_DB_NAME=todo
TODO_DB_USER=change_me_todo_user
TODO_DB_PASSWORD=change_me_todo_password
TODO_DB_ROOT_PASSWORD=change_me_todo_root_password
